@page "/race/{id}"
@model Browser.Pages.RaceModel
@{
    ViewData["Title"] = "レース予想結果";
}

<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"]</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
        }
        h1 {
            color: #333;
        }
        .race-header {
            background-color: #4CAF50;
            color: white;
            padding: 10px;
            margin-bottom: 20px;
        }
        .result-table {
            border-collapse: collapse;
            width: 100%;
        }
        .result-table th, .result-table td {
            border: 1px solid #ddd;
            padding: 8px;
            text-align: center;
        }
        .result-table th {
            background-color: #2196F3;
            color: white;
            position: sticky;
            top: 0;
        }
        .result-table tr:nth-child(even) {
            background-color: #f2f2f2;
        }
        .result-table tr:hover {
            background-color: #ddd;
        }
        .rank-1 { background-color: Red; color: white; font-weight: bold; }
        .rank-2 { background-color: Blue; color: white; font-weight: bold; }
        .rank-3 { background-color: Green; color: white; font-weight: bold; }
        .rank-4 { background-color: MediumPurple; color: white; font-weight: bold; }
        .rank-5 { background-color: Aqua; color: white; font-weight: bold; }
        .rank-6 { background-color: Yellow; font-weight: bold; }
        .rank-7 { background-color: LightYellow; font-weight: bold; }
        .error {
            color: red;
            padding: 20px;
            background-color: #ffe6e6;
            border: 1px solid red;
        }
        .back-link {
            display: inline-block;
            margin-bottom: 20px;
            padding: 10px 20px;
            background-color: #4CAF50;
            color: white;
            text-decoration: none;
            border-radius: 4px;
        }
        .back-link:hover {
            background-color: #45a049;
        }
    </style>
</head>
<body>
    <a href="/" class="back-link">← トップページに戻る</a>

    <h1>レース予想結果</h1>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="error">
            <strong>エラー:</strong> @Model.ErrorMessage
        </div>
    }
    else if (!string.IsNullOrEmpty(Model.RaceHeader))
    {
        <div class="race-header">
            <h2>@Model.RaceHeader</h2>
        </div>

        <table class="result-table">
            <thead>
                <tr>
                    <th rowspan="2">枠番</th>
                    <th rowspan="2">馬番</th>
                    <th rowspan="2">馬名</th>
                    <th rowspan="2">結果</th>
                    <th rowspan="2">単勝</th>
                    <th>Vars1</th>
                    <th>Vars2</th>
                    <th>Medium</th>
                    <th>Small</th>
                    <th>Total</th>
                    <th>Horse</th>
                    <th>EV</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Results)
                {
                    <tr>
                        <td>@item.Wakuban</td>
                        <td>@item.Umaban</td>
                        <td style="text-align: left;">@item.Name</td>
                        <td>@item.Result</td>
                        <td>@item.Odds.ToString("F1")</td>
                        <td class="@GetRankClass(item.Vars1Rank)">@((item.Vars1WinProb * 100).ToString("F1"))%</td>
                        <td class="@GetRankClass(item.Vars2Rank)">@((item.Vars2WinProb * 100).ToString("F1"))%</td>
                        <td class="@GetRankClass(item.TotalMediumRank)">@((item.TotalMediumWinProb * 100).ToString("F1"))%</td>
                        <td class="@GetRankClass(item.TotalSmallRank)">@((item.TotalSmallWinProb * 100).ToString("F1"))%</td>
                        <td class="@GetRankClass(item.TotalRank)">@((item.TotalWinProb * 100).ToString("F1"))%</td>
                        <td class="@GetRankClass(item.HorseRank)">@((item.HorseWinProb * 100).ToString("F1"))%</td>
                        <td class="@GetRankClass(GetEVRank(item, Model.Results))">@item.EV.ToString("F2")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>読み込み中...</p>
    }
</body>
</html>

@functions {
    string GetRankClass(int rank)
    {
        return rank switch
        {
            1 => "rank-1",
            2 => "rank-2",
            3 => "rank-3",
            4 => "rank-4",
            5 => "rank-5",
            6 => "rank-6",
            7 => "rank-7",
            _ => ""
        };
    }

    int GetEVRank(Browser.Pages.RaceResultItem item, IEnumerable<Browser.Pages.RaceResultItem> results)
    {
        return results.OrderByDescending(x => x.EV).Select((x, i) => new { x, Rank = i + 1 }).First(x => x.x == item).Rank;
    }
}
