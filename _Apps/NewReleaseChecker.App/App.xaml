<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:NewReleaseChecker.App.Converters"
             x:Class="NewReleaseChecker.App.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:IntToBoolConverter x:Key="IntToBool" />
            <converters:CountToVisibilityConverter x:Key="CountToVisibility" />
            <converters:StringNotEmptyConverter x:Key="StringNotEmpty" />
            <converters:InverseBoolConverter x:Key="InverseBool" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
