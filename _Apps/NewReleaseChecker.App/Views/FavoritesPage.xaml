<?xml version="1.0" encoding="utf-8" ?>
<views:SelectableBookListPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:NewReleaseChecker.App.Views"
             x:Class="NewReleaseChecker.App.Views.FavoritesPage"
             x:Name="Root"
             Title="お気に入り">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="{Binding SelectionToggleLabel}" Command="{Binding ToggleSelectionModeCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,*,Auto">
        <Grid Grid.Row="0" ColumnDefinitions="*,*" Padding="10,6" ColumnSpacing="10">
            <Picker Grid.Column="0" Title="並び替え" SelectedIndex="{Binding SortOption}">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>発売日順</x:String>
                        <x:String>シリーズ名順</x:String>
                        <x:String>お気に入り登録順</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>
            <Picker Grid.Column="1" Title="フィルタ" SelectedIndex="{Binding FilterOption}">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>すべて</x:String>
                        <x:String>未購入のみ</x:String>
                        <x:String>未発売のみ</x:String>
                        <x:String>未追跡のみ</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>
        </Grid>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Items}" SelectionMode="None">
            <CollectionView.EmptyView>
                <StackLayout Padding="24" VerticalOptions="Center">
                    <Label Text="お気に入りはまだありません" HorizontalOptions="Center" />
                </StackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="10" ColumnDefinitions="Auto,48,*,Auto" ColumnSpacing="10">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding BindingContext.RowTappedCommand, Source={x:Reference Root}}"
                                CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>
                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" InputTransparent="True"
                                  IsVisible="{Binding BindingContext.IsSelectionMode, Source={x:Reference Root}}" />
                        <Image Grid.Column="1" Source="{Binding ImageUrl}" Aspect="AspectFit" WidthRequest="48" HeightRequest="68" />
                        <VerticalStackLayout Grid.Column="2" Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding Title}" LineBreakMode="TailTruncation" />
                            <Label Text="{Binding Author}" FontSize="12" TextColor="{StaticResource Gray500}" />
                            <Label Text="{Binding SeriesName}" FontSize="11" TextColor="{StaticResource Primary}" />
                            <Label Text="{Binding ReleaseDisplay}" FontSize="11" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="3" Spacing="4" VerticalOptions="Center">
                            <Label Text="★" FontSize="14" TextColor="#F5A623" HorizontalOptions="End" IsVisible="{Binding IsFavorite}" />
                            <Label Text="購入済" FontSize="11" TextColor="{StaticResource Primary}" IsVisible="{Binding IsPurchased}" />
                            <Label Text="カレンダー未登録" FontSize="10" TextColor="#856404" IsVisible="{Binding ShowCalendarBadge}" />
                        </VerticalStackLayout>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- 一括操作バー（選択モード時のみ。F-015）。007=購入済/解除/★解除。解除はツールバーの「一覧」で行う -->
        <Grid Grid.Row="2" IsVisible="{Binding IsSelectionMode}" Padding="8" ColumnSpacing="8"
              ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto" BackgroundColor="{StaticResource Gray100}">
            <Label  Grid.Column="0" VerticalOptions="Center" Text="{Binding SelectedCount, StringFormat='{0}件'}" />
            <Button Grid.Column="1" Text="{Binding SelectAllLabel}" Command="{Binding SelectAllCommand}" />
            <Button Grid.Column="3" Text="購入済" Command="{Binding BulkPurchaseCommand}" />
            <Button Grid.Column="4" Text="解除"  Command="{Binding BulkUnpurchaseCommand}" />
            <Button Grid.Column="5" Text="★解除" Command="{Binding BulkUnfavoriteCommand}" />
        </Grid>
    </Grid>
</views:SelectableBookListPage>
