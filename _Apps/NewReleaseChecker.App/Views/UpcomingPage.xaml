<?xml version="1.0" encoding="utf-8" ?>
<views:SelectableBookListPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:NewReleaseChecker.App.Views"
             x:Class="NewReleaseChecker.App.Views.UpcomingPage"
             x:Name="Root"
             Title="発売予定">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="選択" Command="{Binding EnterSelectionModeCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,*,Auto">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Padding="10,6" ColumnSpacing="10">
            <Picker Grid.Column="0" Title="種別" WidthRequest="120" SelectedIndex="{Binding MediaTab}">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>ラノベ</x:String>
                        <x:String>コミック</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>
            <Picker Grid.Column="1" Title="ジャンル" ItemsSource="{Binding Genres}"
                    ItemDisplayBinding="{Binding GenreName}" SelectedItem="{Binding SelectedGenre}" />
        </Grid>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Items}" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="10" ColumnDefinitions="Auto,48,*" ColumnSpacing="10">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding BindingContext.RowTappedCommand, Source={x:Reference Root}}"
                                CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>
                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" InputTransparent="True"
                                  IsVisible="{Binding BindingContext.IsSelectionMode, Source={x:Reference Root}}" />
                        <Image Grid.Column="1" Source="{Binding ImageUrl}" Aspect="AspectFit" WidthRequest="48" HeightRequest="68" />
                        <VerticalStackLayout Grid.Column="2" Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding Title}" LineBreakMode="TailTruncation" />
                            <Label Text="{Binding Author}" FontSize="12" TextColor="{StaticResource Gray500}" />
                            <Label Text="{Binding Publisher}" FontSize="11" />
                            <Label Text="{Binding ReleaseDisplay}" FontSize="11" />
                        </VerticalStackLayout>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator Grid.Row="1" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                           VerticalOptions="Center" HorizontalOptions="Center" />

        <!-- 一括操作バー（選択モード時のみ。F-015）。008=★追加/★解除 -->
        <Grid Grid.Row="2" IsVisible="{Binding IsSelectionMode}" Padding="8" ColumnSpacing="8"
              ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto" BackgroundColor="{StaticResource Gray100}">
            <Label  Grid.Column="0" VerticalOptions="Center" Text="{Binding SelectedCount, StringFormat='{0}件'}" />
            <Button Grid.Column="1" Text="{Binding SelectAllLabel}" Command="{Binding SelectAllCommand}" />
            <Button Grid.Column="3" Text="★追加" Command="{Binding BulkFavoriteCommand}" />
            <Button Grid.Column="4" Text="★解除" Command="{Binding BulkUnfavoriteCommand}" />
            <Button Grid.Column="5" Text="完了"  Command="{Binding ExitSelectionModeCommand}" />
        </Grid>
    </Grid>
</views:SelectableBookListPage>
