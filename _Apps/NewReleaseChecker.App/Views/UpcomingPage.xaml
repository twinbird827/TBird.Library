<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NewReleaseChecker.App.Views.UpcomingPage"
             x:Name="Root"
             Title="発売予定">
    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Padding="10,6" ColumnSpacing="10">
            <Picker Grid.Column="0" Title="種別" WidthRequest="120" SelectedIndex="{Binding MediaTab}">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>ラノベ</x:String>
                        <x:String>コミック</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>
            <Picker Grid.Column="1" Title="ジャンル" ItemsSource="{Binding Genres}"
                    ItemDisplayBinding="{Binding GenreName}" SelectedItem="{Binding SelectedGenre}" />
        </Grid>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Items}" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="10" ColumnDefinitions="48,*" ColumnSpacing="10">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding BindingContext.OpenBookCommand, Source={x:Reference Root}}"
                                CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>
                        <Image Grid.Column="0" Source="{Binding ImageUrl}" Aspect="AspectFit" WidthRequest="48" HeightRequest="68" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding Title}" LineBreakMode="TailTruncation" />
                            <Label Text="{Binding Author}" FontSize="12" TextColor="{StaticResource Gray500}" />
                            <Label Text="{Binding Publisher}" FontSize="11" />
                            <Label Text="{Binding ReleaseDisplay}" FontSize="11" />
                        </VerticalStackLayout>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator Grid.Row="1" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                           VerticalOptions="Center" HorizontalOptions="Center" />
    </Grid>
</ContentPage>
