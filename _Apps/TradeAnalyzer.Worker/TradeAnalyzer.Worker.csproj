<Project Sdk="Microsoft.NET.Sdk.Worker">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>10</LangVersion>
    <UserSecretsId>dotnet-TradeAnalyzer.Worker-8970fed6-8762-4193-aa2c-1778a06c03d6</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="10.0.9">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.9" />
    <!-- F1 レート単体テスト用の決定的 TimeProvider（FakeTimeProvider）。dotnet/extensions 10.7.x 系に合わせる。 -->
    <PackageReference Include="Microsoft.Extensions.TimeProvider.Testing" Version="10.7.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\TradeAnalyzer.Data\TradeAnalyzer.Data.csproj" />
    <ProjectReference Include="..\TradeAnalyzer.Core\TradeAnalyzer.Core.csproj" />
  </ItemGroup>

  <!-- Secrets.json は _Tools/TradeAnalyzer/Secrets.json（AppPaths.SecretsPath）から絶対パスで直接ロードするため
       出力先へのコピーは不要（Program.cs 参照）。 -->
</Project>
