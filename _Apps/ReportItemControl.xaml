<UserControl x:Class="Netkeiba.ReportItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Netkeiba"
			 xmlns:models="clr-namespace:Netkeiba.Models"
             mc:Ignorable="d">
	<UserControl.DataContext>
		<local:ReportItemViewModel />
	</UserControl.DataContext>

	<UserControl.Resources>
		<Style TargetType="GroupBox">
			<Setter Property="Margin" Value="10" />
		</Style>

		<Style TargetType="ProgressBar">
			<Setter Property="Margin" Value="0" />
		</Style>

		<Style TargetType="TextBlock">
			<Setter Property="Margin" Value="3" />
			<Setter Property="MinWidth" Value="60" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style>

		<Style TargetType="TextBox">
			<Setter Property="Margin" Value="3" />
			<Setter Property="Padding" Value="3" />
			<Setter Property="MinWidth" Value="60" />
			<Setter Property="VerticalAlignment" Value="Center" />
			<Setter Property="VerticalContentAlignment" Value="Center" />
		</Style>

		<Style TargetType="CheckBox">
			<Setter Property="Margin" Value="3" />
			<Setter Property="MinWidth" Value="60" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style>

		<Style TargetType="Button">
			<Setter Property="Margin" Value="3" />
			<Setter Property="MinWidth" Value="40" />
			<Setter Property="MinHeight" Value="40" />
		</Style>

		<Style TargetType="ListBox">
			<Setter Property="Margin" Value="5" />
		</Style>

		<DataTemplate x:Key="S4CellItem" DataType="{x:Type models:RaceScore}">
			<Label Content="{Binding Score}" ContentStringFormat="{}{0:F2}">
				<Label.Resources>
					<Style TargetType="Label">
						<Style.Triggers>
							<DataTrigger Binding="{Binding Rank}" Value="1">
								<Setter Property="Background" Value="Red" />
								<Setter Property="Foreground" Value="White" />
								<Setter Property="FontWeight" Value="Bold" />
							</DataTrigger>
							<DataTrigger Binding="{Binding Rank}" Value="2">
								<Setter Property="Background" Value="Blue" />
								<Setter Property="Foreground" Value="White" />
								<Setter Property="FontWeight" Value="Bold" />
							</DataTrigger>
							<DataTrigger Binding="{Binding Rank}" Value="3">
								<Setter Property="Background" Value="Green" />
								<Setter Property="Foreground" Value="White" />
								<Setter Property="FontWeight" Value="Bold" />
							</DataTrigger>
							<DataTrigger Binding="{Binding Rank}" Value="4">
								<Setter Property="Background" Value="MediumPurple" />
								<Setter Property="Foreground" Value="White" />
								<Setter Property="FontWeight" Value="Bold" />
							</DataTrigger>
							<DataTrigger Binding="{Binding Rank}" Value="5">
								<Setter Property="Background" Value="MediumPurple" />
								<Setter Property="Foreground" Value="White" />
								<Setter Property="FontWeight" Value="Bold" />
							</DataTrigger>
							<DataTrigger Binding="{Binding Rank}" Value="6">
								<Setter Property="Background" Value="Yellow" />
								<Setter Property="FontWeight" Value="Bold" />
							</DataTrigger>
							<DataTrigger Binding="{Binding Rank}" Value="7">
								<Setter Property="Background" Value="LightYellow" />
								<Setter Property="FontWeight" Value="Bold" />
							</DataTrigger>
						</Style.Triggers>
					</Style>
				</Label.Resources>
			</Label>
		</DataTemplate>
	</UserControl.Resources>
	<GroupBox Header="{Binding Title}">
		<ListView ItemsSource="{Binding Items}">
			<ListView.ItemContainerStyle>
				<Style TargetType="ListViewItem">
					<Style.Triggers>
						<DataTrigger Binding="{Binding Result}" Value="1">
							<Setter Property="FontWeight" Value="Bold" />
						</DataTrigger>
						<DataTrigger Binding="{Binding Result}" Value="2">
							<Setter Property="FontWeight" Value="Bold" />
						</DataTrigger>
						<DataTrigger Binding="{Binding Result}" Value="3">
							<Setter Property="FontWeight" Value="Bold" />
						</DataTrigger>
					</Style.Triggers>
				</Style>
			</ListView.ItemContainerStyle>
			<ListView.View>
				<GridView>
					<GridViewColumn Header="枠番" Width="50"
									DisplayMemberBinding="{Binding Wakuban}" />
					<GridViewColumn Header="馬番" Width="50"
									DisplayMemberBinding="{Binding Umaban}" />
					<GridViewColumn Header="馬名" Width="200"
									DisplayMemberBinding="{Binding Name}" />
					<GridViewColumn Header="着順" Width="50"
									DisplayMemberBinding="{Binding Result}" />
					<GridViewColumn Header="Total" Width="60">
						<GridViewColumn.CellTemplate>
							<DataTemplate>
								<ContentControl Content="{Binding Total}" ContentTemplate="{StaticResource S4CellItem}" />
							</DataTemplate>
						</GridViewColumn.CellTemplate>
					</GridViewColumn>
					<GridViewColumn Header="All" Width="60">
						<GridViewColumn.CellTemplate>
							<DataTemplate>
								<ContentControl Content="{Binding All}" ContentTemplate="{StaticResource S4CellItem}" />
							</DataTemplate>
						</GridViewColumn.CellTemplate>
					</GridViewColumn>
					<GridViewColumn Header="Horse" Width="60">
						<GridViewColumn.CellTemplate>
							<DataTemplate>
								<ContentControl Content="{Binding Horse}" ContentTemplate="{StaticResource S4CellItem}" />
							</DataTemplate>
						</GridViewColumn.CellTemplate>
					</GridViewColumn>
					<GridViewColumn Header="Jockey" Width="60">
						<GridViewColumn.CellTemplate>
							<DataTemplate>
								<ContentControl Content="{Binding Jockey}" ContentTemplate="{StaticResource S4CellItem}" />
							</DataTemplate>
						</GridViewColumn.CellTemplate>
					</GridViewColumn>
					<GridViewColumn Header="Blood" Width="60">
						<GridViewColumn.CellTemplate>
							<DataTemplate>
								<ContentControl Content="{Binding Blood}" ContentTemplate="{StaticResource S4CellItem}" />
							</DataTemplate>
						</GridViewColumn.CellTemplate>
					</GridViewColumn>
					<GridViewColumn Header="Conn" Width="60">
						<GridViewColumn.CellTemplate>
							<DataTemplate>
								<ContentControl Content="{Binding Connection}" ContentTemplate="{StaticResource S4CellItem}" />
							</DataTemplate>
						</GridViewColumn.CellTemplate>
					</GridViewColumn>
				</GridView>
			</ListView.View>
		</ListView>
	</GroupBox>
</UserControl>